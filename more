</head>
<body>
  <main class="console">
    <a href="index.html">[ return to collection ]</a>
    <h1>PROJECT TC_BDSV: THE STRATEGIC INSIDER</h1>

    <section class="panel">
      <h2>PHASE ROLLOUT: <span id="meter-text">[|||||-----] 50%</span></h2>
      <div class="meter" aria-hidden="true">SYSTEM GRAPH: [|||||-----]</div>
      <ul class="phase-list">
        <li class="phase">
          <span>&gt; Phase 1: Noise &amp; Light Discipline</span>
          <strong class="status active">ACTIVE</strong>
        </li>
        <li class="phase">
          <span>&gt; Phase 2: Glitch Aesthetic Injection</span>
          <strong class="status pending">PENDING</strong>
        </li>
        <li class="phase">
          <span>&gt; Phase 3: Total Blackout</span>
          <strong class="status locked">LOCKED</strong>
        </li>
        <li class="phase">
          <span>&gt; Phase 4: Revenue Engine Engagement</span>
          <strong class="status locked">LOCKED</strong>
        </li>
      </ul>
    </section>

    <div class="countdown" id="countdown">COUNTDOWN TO BLACKOUT: 04:22:11</div>
    <p class="footer">Maintain operational security. N4 engine is primed.</p>
  </main>

  <script>
    const countdownElement = document.getElementById("countdown");
    const meterText = document.getElementById("meter-text");
    let remainingSeconds = (4 * 60 * 60) + (22 * 60) + 11;

    function formatCountdown(totalSeconds) {
      const hours = String(Math.floor(totalSeconds / 3600)).padStart(2, "0");
      const minutes = String(Math.floor((totalSeconds % 3600) / 60)).padStart(2, "0");
      const seconds = String(totalSeconds % 60).padStart(2, "0");
      return hours + ":" + minutes + ":" + seconds;
    }

    function updateCountdown() {
      countdownElement.textContent = "COUNTDOWN TO BLACKOUT: " + formatCountdown(remainingSeconds);

      if (remainingSeconds > 0) {
        remainingSeconds -= 1;
      } else {
        countdownElement.textContent = "COUNTDOWN TO BLACKOUT: 00:00:00";
        meterText.textContent = "[||||||||||] 100%";
      }
    }

    updateCountdown();
    setInterval(updateCountdown, 1000);
  </script>
</body>
</html>

